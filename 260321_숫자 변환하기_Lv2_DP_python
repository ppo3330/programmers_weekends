#O(N)

#단순 DP

def solution(x, y, n):
    answer = 0
    MAX = 1000001
    dp = [MAX]*(4*y)
    dp[x] = 0
    for i in range(y+1):
        if dp[i] == MAX:
            continue
        else:
            dp[i+n] = min(dp[i]+1, dp[i+n])
            dp[i*2] = min(dp[i]+1, dp[2*i])
            dp[i*3] = min(dp[i]+1, dp[3*i])
    answer = dp[y]
    if answer == MAX:
        answer = -1
    return answer
