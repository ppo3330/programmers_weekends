#include <string>
#include <vector>
#include <queue>

using namespace std;

vector<int> solution(vector<int> numbers) {
    int l = numbers.size();
    vector<int> answer(l,-1);

    priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>> pq;
    pq.push({numbers[0],0});
    for(int i=1;i<l;i++){
        while(true){
            if (pq.size() == 0)
                break;
            auto top = pq.top();
            if (top.first < numbers[i]){
                pq.pop();
                answer[top.second] = numbers[i];
            }
            else{
                break;
            }
        }
        pq.push({numbers[i],i});
    }
    
    return answer;
}
